# ─────────────────────────────────────────────
# FastAPI Backend — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# App
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/adaptive_ai

# Anthropic (primary LLM)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (optional, for model-agnostic support)
# OPENAI_API_KEY=sk-...

# Search (Phase 7) — Tavily
TAVILY_API_KEY=tvly-...

# MCP Servers (Phase 7)
MCP_WEB_SEARCH_ENABLED=true
MCP_GOOGLE_CALENDAR_ENABLED=false
MCP_GITHUB_ENABLED=false
MCP_NOTION_ENABLED=false
MCP_GMAIL_ENABLED=false

# MCP Credentials
GITHUB_TOKEN=ghp_...
NOTION_TOKEN=secret_...

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]
