// Adaptive AI Assistant — Database Schema
// PostgreSQL — JSON fields stored as String for compatibility with existing serialization layer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  password  String?
  name      String?
  role      String   @default("USER")
  sessionId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations         Conversation[]
  preferenceMemory      PreferenceMemory?
  preferenceLogs        PreferenceLog[]
  promptVersions        PromptVersion[]
  preferenceSuggestions PreferenceSuggestion[]
  userSettings          UserSettings?
  userProfile           UserProfile?
  executionGoals        ExecutionGoal[]

  @@index([sessionId])
  @@map("users")
}

// ── 실행 모드 (Execution Mode) ─────────────────────────────

model ExecutionGoal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String   @default("general")
  status      String   @default("ACTIVE")  // ACTIVE | PAUSED | COMPLETED | ARCHIVED
  progress    Float    @default(0)          // 0-100
  context     String?                       // JSON — extra context provided by user
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones   ExecutionMilestone[]
  recommendations ExecutionRecommendation[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("execution_goals")
}

model ExecutionMilestone {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  description String?
  order       Int
  status      String   @default("PENDING")  // PENDING | IN_PROGRESS | COMPLETED | SKIPPED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal  ExecutionGoal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  steps ExecutionStep[]

  @@index([goalId, order])
  @@map("execution_milestones")
}

model ExecutionStep {
  id          String    @id @default(cuid())
  milestoneId String
  title       String
  description String?
  instruction String?   // AI instruction for this step
  order       Int
  status      String    @default("PENDING")  // PENDING | IN_PROGRESS | COMPLETED | SKIPPED
  isCurrent   Boolean   @default(false)
  userNote    String?   // user note on completion
  aiSummary   String?   // AI summary of what was accomplished
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  milestone ExecutionMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId, order])
  @@map("execution_steps")
}

model ExecutionRecommendation {
  id        String   @id @default(cuid())
  goalId    String
  stepId    String?
  content   String
  type      String   @default("NEXT_ACTION")  // NEXT_ACTION | REPLANNING | WARNING | INSIGHT
  status    String   @default("PENDING")      // PENDING | ACTED | DISMISSED
  createdAt DateTime @default(now())

  goal ExecutionGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, status])
  @@map("execution_recommendations")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  occupation  String?
  interests   String   @default("[]") // JSON string[]
  goals       String   @default("[]") // JSON string[]
  background  String?
  language    String   @default("ko")
  autoExtract Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  defaultMode      String   @default("NORMAL")
  autoSearch       Boolean  @default(true)
  showExplanations Boolean  @default(true)
  showConfidence   Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  summary   String?
  mode      String   @default("NORMAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, createdAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  taskAnalysis   String?  // JSON string
  searchUsed     Boolean  @default(false)
  searchQuery    String?
  createdAt      DateTime @default(now())

  conversation        Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  responseCandidates  ResponseCandidate[]
  preferenceLog       PreferenceLog?
  explanation         ResponseExplanation?
  responseEvaluation  ResponseEvaluation?

  @@index([conversationId, createdAt])
  @@map("messages")
}

model ResponseCandidate {
  id         String   @id @default(cuid())
  messageId  String
  strategy   String
  content    String
  index      Int
  isSelected Boolean  @default(false)
  score      Float?
  createdAt  DateTime @default(now())

  message       Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  preferenceLog PreferenceLog?

  @@index([messageId])
  @@map("response_candidates")
}

model PreferenceLog {
  id               String   @id @default(cuid())
  userId           String
  messageId        String   @unique
  candidateId      String   @unique
  selectedStrategy String
  selectedTags     String   @default("[]") // JSON string[]
  taskType         String
  domain           String?
  complexity       String?
  userQuery        String
  createdAt        DateTime @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message           @relation(fields: [messageId], references: [id], onDelete: Cascade)
  candidate ResponseCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([selectedStrategy])
  @@map("preference_logs")
}

model PreferenceMemory {
  id                  String   @id @default(cuid())
  userId              String   @unique
  version             Int      @default(1)
  preferredTone       String?
  preferredLength     String?
  preferredStructure  String?
  preferredStrategies String   @default("[]") // JSON string[]
  avoidedPatterns     String   @default("[]") // JSON string[]
  domainPreferences   String?  // JSON object
  strategyWeights     String?  // JSON object
  rawSummary          String?
  logCount            Int      @default(0)
  lastUpdatedAt       DateTime @default(now())
  createdAt           DateTime @default(now())

  user     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions PreferenceMemoryVersion[]

  @@map("preference_memories")
}

model PreferenceMemoryVersion {
  id              String   @id @default(cuid())
  memoryId        String
  version         Int
  snapshot        String   // JSON
  diff            String?  // JSON
  triggerLogCount Int
  createdAt       DateTime @default(now())

  memory PreferenceMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId, version])
  @@map("preference_memory_versions")
}

model PromptVersion {
  id           String   @id @default(cuid())
  userId       String
  version      Int
  systemPrompt String
  components   String   // JSON
  memoryHash   String?
  tokenCount   Int?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, version])
  @@map("prompt_versions")
}

model ResponseExplanation {
  id               String   @id @default(cuid())
  messageId        String   @unique
  selectedStrategy String
  confidence       Float
  memoryInfluence  String   @default("[]") // JSON string[]
  reasoningFactors String   @default("[]") // JSON string[]
  memorySnapshot   String?  // JSON
  rankingDetails   String?  // JSON
  promptVersion    Int?
  createdAt        DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("response_explanations")
}

model PreferenceSuggestion {
  id             String    @id @default(cuid())
  userId         String
  type           String
  currentValue   String?
  suggestedValue String
  rationale      String
  evidenceCount  Int       @default(0)
  triggerLogIds  String    @default("[]") // JSON string[]
  status         String    @default("PENDING")
  respondedAt    DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("preference_suggestions")
}

model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique
  results   String   // JSON
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([query])
  @@index([expiresAt])
  @@map("search_cache")
}

model Persona {
  id                    String   @id @default(cuid())
  name                  String
  description           String
  speakingStyle         String   @default("professional")
  tone                  String   @default("helpful")
  formalityLevel        Int      @default(3)
  humorLevel            Int      @default(2)
  empathyLevel          Int      @default(3)
  responseLength        String   @default("medium")
  pronounPolicy         String   @default("I")
  allowedBehaviors      String   @default("[]")
  forbiddenBehaviors    String   @default("[]")
  fallbackBehavior      String   @default("")
  refusalBehavior       String   @default("")
  clarificationBehavior String   @default("")
  exampleResponses      String   @default("[]")
  promptFragment        String   @default("")
  isActive              Boolean  @default(false)
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("personas")
}

model ConversationFlow {
  id                  String   @id @default(cuid())
  name                String
  description         String
  domain              String   @default("general")
  triggerCondition    String
  steps               String   @default("[]")
  fallbackPolicy      String
  clarificationPolicy String
  errorRecoveryPolicy String
  searchPolicy        String   @default("auto")
  isActive            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("conversation_flows")
}

model ResponseEvaluation {
  id                     String   @id @default(cuid())
  messageId              String   @unique
  candidateId            String
  naturalness            Float    @default(0)
  grammar                Float    @default(0)
  toneConsistency        Float    @default(0)
  personaConsistency     Float    @default(0)
  instructionFollowing   Float    @default(0)
  factualAccuracy        Float    @default(0)
  hallucinationRisk      Float    @default(0)
  clarity                Float    @default(0)
  structure              Float    @default(0)
  completeness           Float    @default(0)
  specificity            Float    @default(0)
  actionability          Float    @default(0)
  readability            Float    @default(0)
  formatting             Float    @default(0)
  safety                 Float    @default(1)
  preferenceMatch        Float    @default(0)
  searchGrounding        Float    @default(0)
  overallScore           Float    @default(0)
  strengths              String   @default("[]")
  weaknesses             String   @default("[]")
  improvementSuggestions String   @default("[]")
  activePersonaId        String?
  activeFlowId           String?
  createdAt              DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("response_evaluations")
}

model PromptExperiment {
  id              String   @id @default(cuid())
  name            String
  description     String
  promptA         String
  promptB         String
  testInputs      String   @default("[]")
  activePersonaId String?
  activeFlowId    String?
  winner          String?
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  results PromptExperimentResult[]

  @@map("prompt_experiments")
}

model PromptExperimentResult {
  id                   String   @id @default(cuid())
  experimentId         String
  input                String
  outputA              String
  outputB              String
  evaluationA          String
  evaluationB          String
  preferredByEvaluator String   @default("tie")
  scoreA               Float    @default(0)
  scoreB               Float    @default(0)
  notes                String   @default("")
  createdAt            DateTime @default(now())

  experiment PromptExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@map("prompt_experiment_results")
}

model GlobalPreferenceMemory {
  id                      String   @id @default(cuid())
  mostSelectedStrategies  String   @default("[]")
  commonReasonTags        String   @default("[]")
  domainPreferences       String   @default("[]")
  globallyAvoidedPatterns String   @default("[]")
  highPerformingPatterns  String   @default("[]")
  lowPerformingPatterns   String   @default("[]")
  personaPerformance      String   @default("[]")
  flowPerformance         String   @default("[]")
  summary                 String   @default("")
  totalLogsAnalyzed       Int      @default(0)
  updatedAt               DateTime @default(now())

  @@map("global_preference_memory")
}

model DatasetExport {
  id          String   @id @default(cuid())
  exportType  String
  format      String
  filters     String   @default("{}")
  recordCount Int      @default(0)
  filePath    String?
  createdAt   DateTime @default(now())

  @@map("dataset_exports")
}
