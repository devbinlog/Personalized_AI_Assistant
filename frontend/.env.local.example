# ─────────────────────────────────────────────
# Adaptive AI Assistant — Environment Variables
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/adaptive_ai"

# ── LLM Provider ──────────────────────────────
# Options: mock | openai | anthropic | google
# Default: openai  (mock = no API key needed)
LLM_PROVIDER="mock"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_FAST_MODEL="gpt-4o-mini"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"
ANTHROPIC_FAST_MODEL="claude-haiku-4-5-20251001"

# Google
GOOGLE_API_KEY="AIza..."
GOOGLE_MODEL="gemini-2.5-pro"
GOOGLE_FAST_MODEL="gemini-2.0-flash"

# Web Search (Phase 7) — Tavily API
TAVILY_API_KEY="tvly-..."

# CORS
ALLOWED_ORIGIN="http://localhost:3000"

# Next.js public vars (exposed to browser — no secrets!)
NEXT_PUBLIC_APP_NAME="Adaptive AI Assistant"
NEXT_PUBLIC_DEFAULT_MODE="NORMAL"
