# ── AI Provider ───────────────────────────────────────────────
# Options: mock | openai | anthropic | google
# mock = no API key needed (rule-based responses for local dev)
LLM_PROVIDER=mock

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Database ───────────────────────────────────────────────────
# SQLite (local dev): file:./prisma/dev.db
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL=file:./prisma/dev.db

# ── NextAuth ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
# Must match the deployment URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ── Web Search (optional) ─────────────────────────────────────
# Get a free key at https://tavily.com
TAVILY_API_KEY=

# ── LangGraph Backend (optional) ─────────────────────────────
# FastAPI backend URL. Set to http://localhost:8000 if running locally.
# Leave as 9999 to disable (frontend falls back to local AI pipeline).
LANGGRAPH_BACKEND_URL=http://localhost:9999

# ── Vercel Cron (production only) ────────────────────────────
# Protects the /api/cron/global-learning endpoint.
# Generate: openssl rand -base64 32
CRON_SECRET=

# ── CORS (production only) ────────────────────────────────────
# Set to your production frontend URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:3000
